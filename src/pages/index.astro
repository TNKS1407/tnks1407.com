    <!-- 改善を送る（非公開・ページURL自動添付） -->
    <ImproveButton />

    <!-- Tinks roaming sprite -->
    <canvas id="tinks" style="position:fixed;bottom:0;left:0;pointer-events:none;z-index:999;image-rendering:pixelated;image-rendering:crisp-edges;"></canvas>
    <div id="tinks-bubble" style="position:fixed;bottom:0;left:0;pointer-events:none;z-index:1000;display:none;background:#fff;border:1.5px solid #c8bfb2;border-radius:12px 12px 12px 2px;padding:0.4rem 0.75rem;font-family:'Zen Kaku Gothic New',sans-serif;font-size:0.78rem;font-weight:500;color:#1d1b17;white-space:nowrap;box-shadow:0 2px 10px rgba(29,27,23,0.1);"></div>

    <script is:inline>
    // Fetch recent posts from tnkblog RSS
    (async () => {
      const wrap = document.getElementById('blog-posts');
      if (!wrap) return;
      try {
        const res = await fetch('https://tnkblog.net/rss.xml', { cache: 'no-store' });
        const text = await res.text();
        const parser = new DOMParser();
        const doc = parser.parseFromString(text, 'application/xml');
        const items = [...doc.querySelectorAll('item')].slice(0, 4);
        if (!items.length) { wrap.innerHTML = '<span class="blog-loading">記事がありません</span>'; return; }
        wrap.innerHTML = items.map(item => {
          const title = item.querySelector('title')?.textContent?.trim() ?? '';
          const link  = item.querySelector('link')?.textContent?.trim() ?? '#';
          const pub   = item.querySelector('pubDate')?.textContent?.trim() ?? '';
          const date  = pub ? new Date(pub).toLocaleDateString('ja-JP', { month: 'numeric', day: 'numeric' }) : '';
          return `<a class="blog-post-item" href="${link}" target="_blank" rel="noopener noreferrer">
            <span class="blog-post-date">${date}</span>
            <span class="blog-post-title">${title}</span>
          </a>`;
        }).join('');
      } catch {
        wrap.innerHTML = '<span class="blog-loading">— tnkblog.net</span>';
      }
    })();
    </script>
    <script define:vars={{ works }} is:inline>
    // Prompt modal — is:inline makes functions globally accessible
    window.openPrompt = function(btn) {
      const idx = parseInt(btn.dataset.idx);
      const w = works[idx];
      document.getElementById('modal-title').textContent = w.title + ' — 作成プロンプト';
      document.getElementById('modal-content').textContent = w.prompt || '';
      document.getElementById('modal-overlay').classList.add('open');
    };
    window.closePrompt = function(e) {
      if (!e || e.target === document.getElementById('modal-overlay')) {
        document.getElementById('modal-overlay').classList.remove('open');
      }
    };

    // Preview modal — live iframe of the tool
    window.openPreview = function(btn) {
      const url = btn.dataset.url, title = btn.dataset.title;
      const overlay = document.getElementById('preview-overlay');
      const frame = document.getElementById('preview-frame');
      const loading = document.getElementById('preview-loading');
      document.getElementById('preview-title').textContent = title;
      document.getElementById('preview-open').href = url;
      loading.style.display = 'flex';
      loading.textContent = '読み込み中…';
      frame.onload = function() { loading.style.display = 'none'; };
      frame.src = url;
      overlay.classList.add('open');
      // 一部のサイトは枠内表示を拒否することがある。数秒で読めなければ新しいタブへ促す。
      clearTimeout(window._pvTimer);
      window._pvTimer = setTimeout(() => {
        if (loading.style.display !== 'none') {
          loading.innerHTML = 'このサイトは枠内表示できないみたい。<br>上の「新しいタブで開く ↗」から見てね。';
        }
      }, 6000);
    };
    window.closePreview = function(e) {
      if (!e || e.target === document.getElementById('preview-overlay')) {
        const overlay = document.getElementById('preview-overlay');
        overlay.classList.remove('open');
        const frame = document.getElementById('preview-frame');
        frame.src = 'about:blank';           // 背後でのロード/音を止める
        clearTimeout(window._pvTimer);
      }
    };
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        document.getElementById('modal-overlay').classList.remove('open');
        window.closePreview();
      }
    });
    </script>

    <script>
    /* ---- hero: 待機/手振りするアバター + 背景の信号アート ---- */
    (() => {
      // アバターのコマ送り（idle 6 / wave 4。CSS背景の position を動かす）
      const av = document.querySelector('.hero-avatar');
      if (av) {
        let FW, RH, NUDGE;
        function calib() {
          const boxW = av.getBoundingClientRect().width || 76;
          const sizeW = boxW * 7.5;
          av.style.backgroundSize = sizeW + 'px auto';
          const scale = sizeW / 1536;
          FW = 192 * scale; RH = 208 * scale; NUDGE = 4 * (boxW / 76);
        }
        calib(); window.addEventListener('resize', calib);
        const FRAMES = { idle: 6, wave: 4 }, ROW = { idle: 0, wave: 3 };
        let st = 'idle', f = 0, cyc = 0;
        const paint = () => { av.style.backgroundPosition = `${-f * FW}px ${-(ROW[st] * RH) - NUDGE}px`; };
        paint();
        setInterval(() => {
          f++;
          if (f >= FRAMES[st]) {
            f = 0;
            if (st === 'wave') st = 'idle';
            else { cyc++; if (cyc >= 5) { cyc = 0; st = 'wave'; } }   // 数周ごとに手を振る
          }
          paint();
        }, 150);
        av.addEventListener('mouseenter', () => { if (st === 'idle') { st = 'wave'; f = 0; paint(); } });
      }

      // 背景: ゆっくり回るエピサイクルが曲線を描く（RF/信号っぽい個性）
      const hb = document.getElementById('hero-bg');
      if (hb) {
        const hctx = hb.getContext('2d');
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        let HW, HH;
        function hresize() {
          const r = hb.parentElement.getBoundingClientRect();
          HW = hb.width = Math.round(r.width * dpr);
          HH = hb.height = Math.round(r.height * dpr);
        }
        hresize(); window.addEventListener('resize', hresize);
        const accent = (getComputedStyle(document.documentElement).getPropertyValue('--accent').trim()) || '#3c7876';
        const circles = [{ f: 1, p: 0, k: 0.60 }, { f: -3, p: 1.3, k: 0.30 }, { f: 5, p: 0.4, k: 0.15 }];
        const trail = [];
        let t = 0, raf = 0;
        function hdraw() {
          hctx.clearRect(0, 0, HW, HH);
          const cx = HW * 0.80, cy = HH * 0.5, R = Math.min(HW, HH) * 0.34;
          // エピサイクルの円（薄く）
          hctx.strokeStyle = accent; hctx.lineWidth = 1 * dpr;
          let px = cx, py = cy;
          hctx.globalAlpha = 0.16;
          for (const c of circles) {
            hctx.beginPath(); hctx.arc(px, py, R * c.k, 0, Math.PI * 2); hctx.stroke();
            px += R * c.k * Math.cos(c.f * t + c.p);
            py += R * c.k * Math.sin(c.f * t + c.p);
          }
          // 先端の軌跡
          trail.push([px, py]); if (trail.length > 300) trail.shift();
          hctx.globalAlpha = 0.85; hctx.lineWidth = 1.6 * dpr;
          hctx.beginPath();
          trail.forEach(([x, y], i) => i ? hctx.lineTo(x, y) : hctx.moveTo(x, y));
          hctx.stroke();
          // 先端の点
          hctx.globalAlpha = 1; hctx.fillStyle = accent;
          hctx.beginPath(); hctx.arc(px, py, 2.4 * dpr, 0, Math.PI * 2); hctx.fill();
          t += 0.012;
          raf = requestAnimationFrame(hdraw);
        }
        // タブが見えないときは止める（軽さのため）
        document.addEventListener('visibilitychange', () => {
          if (document.hidden) { cancelAnimationFrame(raf); raf = 0; }
          else if (!raf) raf = requestAnimationFrame(hdraw);
        });
        hdraw();
      }
    })();
    </script>

    <script>
    /* ---- お気に入り（★）: 作品ごと・一人一回（localStorage＋サーバIP重複チェック） ---- */
    (() => {
      const API = 'https://feedback.tnks1407.com';
      const btns = [...document.querySelectorAll('.fav-btn[data-fav]')];
      if (!btns.length) return;
      const fill = (b) => {
        b.classList.add('faved'); b.setAttribute('aria-pressed', 'true');
        const s = b.querySelector('.star'); if (s) s.textContent = '★';
      };
      const setN = (b, n) => { const e = b.querySelector('.fav-n'); if (e) e.textContent = String(n); };
      fetch(API + '/favs').then(r => r.json()).then(d => {
        btns.forEach(b => {
          const k = b.dataset.fav;
          setN(b, d[k] || 0);
          if (localStorage.getItem('_faved_' + k)) fill(b);
        });
      }).catch(() => btns.forEach(b => setN(b, 0)));
      btns.forEach(b => b.addEventListener('click', () => {
        const k = b.dataset.fav;
        if (localStorage.getItem('_faved_' + k)) return;
        localStorage.setItem('_faved_' + k, '1'); fill(b);
        fetch(API + '/fav?key=' + encodeURIComponent(k), { method: 'POST' })
          .then(r => r.json()).then(d => { if (typeof d.count === 'number') setN(b, d.count); }).catch(() => {});
      }));
    })();
    </script>

