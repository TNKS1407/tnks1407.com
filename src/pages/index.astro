    <script is:inline>
    // Fetch recent posts from tnkblog RSS
    (async () => {
      const wrap = document.getElementById('blog-posts');
      if (!wrap) return;
      try {
        const res = await fetch('https://tnkblog.net/rss.xml', { cache: 'no-store' });
        const text = await res.text();
        const parser = new DOMParser();
        const doc = parser.parseFromString(text, 'application/xml');
        const items = [...doc.querySelectorAll('item')].slice(0, 4);
        if (!items.length) { wrap.innerHTML = '<span class="blog-loading">記事がありません</span>'; return; }
        wrap.innerHTML = items.map(item => {
          const title = item.querySelector('title')?.textContent?.trim() ?? '';
          const link  = item.querySelector('link')?.textContent?.trim() ?? '#';
          const pub   = item.querySelector('pubDate')?.textContent?.trim() ?? '';
          const date  = pub ? new Date(pub).toLocaleDateString('ja-JP', { month: 'numeric', day: 'numeric' }) : '';
          return `<a class="blog-post-item" href="${link}" target="_blank" rel="noopener noreferrer">
            <span class="blog-post-date">${date}</span>
            <span class="blog-post-title">${title}</span>
          </a>`;
        }).join('');
      } catch {
        wrap.innerHTML = '<span class="blog-loading">— tnkblog.net</span>';
      }
    })();
    </script>
    <script define:vars={{ works }} is:inline>
    // Prompt modal — is:inline makes functions globally accessible
    window.openPrompt = function(btn) {
      const idx = parseInt(btn.dataset.idx);
      const w = works[idx];
      document.getElementById('modal-title').textContent = w.title + ' — 作成プロンプト';
      document.getElementById('modal-content').textContent = w.prompt || '';
      document.getElementById('modal-overlay').classList.add('open');
    };
    window.closePrompt = function(e) {
      if (!e || e.target === document.getElementById('modal-overlay')) {
        document.getElementById('modal-overlay').classList.remove('open');
      }
    };
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') document.getElementById('modal-overlay').classList.remove('open');
    });
