          if(open){ rest.removeAttribute('hidden'); btn.textContent='閉じる ▴'; btn.setAttribute('aria-expanded','true'); }
          else { rest.setAttribute('hidden',''); btn.textContent='すべてのツール ▾'; btn.setAttribute('aria-expanded','false'); }
        });
      })();
    </script>
