    <script>
    (() => {
      const SHEET_URL = '/spritesheet.webp';
      const CW = 192, CH = 208, COLS = 8;
      const getScale = () => window.innerWidth < 480 ? 0.65 : window.innerWidth < 768 ? 0.9 : 1.25;
      let SCALE = getScale();
      let DRAW_W = CW * SCALE, DRAW_H = CH * SCALE;
      const STATES = {
        idle:{row:0,frames:6},runR:{row:1,frames:8},runL:{row:2,frames:8},
        wave:{row:3,frames:4},jump:{row:4,frames:5},wait:{row:6,frames:6},run:{row:7,frames:6},
      };

      const h = new Date().getHours();
      const TIME_QUIPS =
        h>=6&&h<12  ? ['おはよう！','今日は何を作る？','コードが気持ちいい時間帯だよ','朝型だね','早起きは三文の徳とか言うよ'] :
        h>=12&&h<17 ? ['お昼ちゃんと食べた？','ちょっと休憩しよ','ふむ…','コードより眠気が勝ちそう','いい感じじゃない？'] :
        h>=17&&h<21 ? ['夕方だよ','今日どこまで進んだ？','そろそろ一区切りかな','コードは詩だよ','いい仕事したね'] :
                      ['夜更かしはほどほどにね','…静かだ','またいる','まだ起きてるの？','深夜のコードは後で読めないやつ'];
      const CARD_QUIPS = ['これ作ったの？','気になる','触ってみてよ','面白いよ','へえ〜'];
      const PET_QUIPS  = ['くすぐったいよ','なでなでしすぎ…','もう…','えへへ','止まらないの？'];
      const JUMP_QUIPS = ['ひょいっ','たかーい','気持ちいい','またやって','ぴょん'];

      function randQuip(arr) { return arr[Math.floor(Math.random()*arr.length)]; }

      const canvas = document.getElementById('tinks');
      function resizeCanvas(){SCALE=getScale();DRAW_W=CW*SCALE;DRAW_H=CH*SCALE;canvas.width=DRAW_W;canvas.height=DRAW_H;}
      resizeCanvas();
      const ctx=canvas.getContext('2d');
      const bubble=document.getElementById('tinks-bubble');
      const off=document.createElement('canvas');off.width=CW;off.height=CH;
      const offCtx=off.getContext('2d');
      const img=new Image();img.crossOrigin='anonymous';img.src=SHEET_URL;

      let posX=40, velX=0.8, state='idle', frame=0, stateTimer=0;
      const FPS=8, FRAME_MS=1000/FPS;

      /* ---- footprints ---- */
      const footCanvas = document.createElement('canvas');
      footCanvas.style.cssText='position:fixed;inset:0;pointer-events:none;z-index:997;';
      document.body.appendChild(footCanvas);
      const footCtx = footCanvas.getContext('2d');
      const footResize = () => { footCanvas.width=window.innerWidth; footCanvas.height=window.innerHeight; };
      footResize(); window.addEventListener('resize', footResize);
      const footprints = [];
      let footStep = 0;
      function addFootprint() {
        if (state !== 'runR' && state !== 'runL') return;
        footStep++;
        if (footStep % 18 !== 0) return;
        const side = state === 'runR' ? 1 : -1;
        footprints.push({
          x: posX + DRAW_W * 0.45 + side * DRAW_W * 0.18,
          y: window.innerHeight - 6,
          life: 1.0,
          flip: side < 0,
        });
        if (footprints.length > 30) footprints.shift();
      }
      function drawFootprints() {
        footCtx.clearRect(0, 0, footCanvas.width, footCanvas.height);
        for (const f of footprints) {
          f.life -= 0.012;
          if (f.life <= 0) continue;
          footCtx.save();
          footCtx.globalAlpha = f.life * 0.45;
          footCtx.fillStyle = '#3c7876';
          footCtx.beginPath();
          const rx = f.flip ? -4 : 4;
          footCtx.ellipse(f.x, f.y, 4, 2.5, f.flip ? -0.3 : 0.3, 0, Math.PI*2);
          footCtx.fill();
          footCtx.restore();
        }
        footprints.splice(0, footprints.filter(f => f.life <= 0).length);
      }

      /* ---- pet counter ---- */
      let petCount = 0, petTimer = null;

      function chromaKey(d){for(let i=0;i<d.length;i+=4)if(d[i]>200&&d[i+1]<80&&d[i+2]>200)d[i+3]=0;}
      function drawSprite(){
        const s=STATES[state];
        offCtx.clearRect(0,0,CW,CH);
        offCtx.drawImage(img,(frame%COLS)*CW,s.row*CH,CW,CH,0,0,CW,CH);
        const d=offCtx.getImageData(0,0,CW,CH);chromaKey(d.data);offCtx.putImageData(d,0,0);
        ctx.clearRect(0,0,DRAW_W,DRAW_H);ctx.imageSmoothingEnabled=false;
        ctx.drawImage(off,0,0,DRAW_W,DRAW_H);
      }
      function positionCanvas(){
        const maxX=window.innerWidth-DRAW_W;
        posX=Math.max(0,Math.min(maxX,posX));
        canvas.style.left=posX+'px';canvas.style.bottom='0px';
        bubble.style.left=(posX+DRAW_W*0.1)+'px';bubble.style.bottom=(DRAW_H+8)+'px';
      }
      function showBubble(text, dur=2800){
        bubble.textContent=text;
        bubble.style.display='block';
        clearTimeout(bubble._t);
        bubble._t=setTimeout(()=>{bubble.style.display='none';},dur);
      }
      function pickState(){
        const r=Math.random();
        if(r<0.35){state='runR';velX=1.2;}
        else if(r<0.7){state='runL';velX=-1.2;}
        else if(r<0.82){state='wave';velX=0;showBubble(randQuip(TIME_QUIPS));}
        else if(r<0.9){state='jump';velX=0;}
        else{state='idle';velX=0;}
        stateTimer=120+Math.random()*180;frame=0;
      }
      let lastTs=0;
      function tick(ts){
        if(!img.complete){requestAnimationFrame(tick);return;}
        if(ts-lastTs>FRAME_MS){
          frame=(frame+1)%STATES[state].frames;
          posX+=velX;
          const maxX=window.innerWidth-DRAW_W;
          if(posX<=0){posX=0;velX=Math.abs(velX);state='runR';frame=0;}
          if(posX>=maxX){posX=maxX;velX=-Math.abs(velX);state='runL';frame=0;}
          if(--stateTimer<=0)pickState();
          addFootprint();
          drawSprite();drawFootprints();positionCanvas();lastTs=ts;
        }
        requestAnimationFrame(tick);
      }
      img.onload=()=>{posX=Math.random()*(window.innerWidth-DRAW_W*2)+DRAW_W;pickState();requestAnimationFrame(tick);};
      window.addEventListener('resize',()=>{resizeCanvas();positionCanvas();});

      /* ---- click anywhere → wave ---- */
      document.addEventListener('click',e=>{
        if(e.target===canvas||e.target.closest('.modal-overlay,.prompt-btn,.fb-overlay'))return;
        state='wave';velX=0;frame=0;stateTimer=60;showBubble(randQuip(TIME_QUIPS));
      });

      /* ---- click on Rankine → pet ---- */
      canvas.addEventListener('click', e => {
        e.stopPropagation();
        petCount++;
        clearTimeout(petTimer);
        petTimer = setTimeout(() => { petCount = 0; }, 1200);
        if (petCount >= 5) {
          state='jump';velX=0;frame=0;stateTimer=80;
          showBubble(randQuip(PET_QUIPS), 3200);
          petCount = 0;
        } else {
          state='wave';velX=0;frame=0;stateTimer=50;
          showBubble(randQuip(PET_QUIPS));
        }
      });

      /* ---- hover near Rankine → react ---- */
      document.addEventListener('mousemove',e=>{
        const cx=posX+DRAW_W/2,cy=window.innerHeight-DRAW_H/2;
        const dist=Math.hypot(e.clientX-cx,e.clientY-cy);
        if(dist<DRAW_W*0.9&&state!=='wave'&&state!=='jump'){
          const dir=posX+DRAW_W/2<e.clientX?'runL':'runR';
          if(state!==dir){state=dir;velX=dir==='runR'?2.8:-2.8;frame=0;stateTimer=80;}
        } else if(dist<DRAW_W*1.8&&state!=='wave'&&state!=='jump'){
          state='idle';velX=0;stateTimer=40;
        }
      });

      /* ---- hover on work card → Rankine runs toward it ---- */
      let cardHoverTimer = null;
      document.querySelectorAll('.work-card').forEach(card => {
        card.addEventListener('mouseenter', () => {
          cardHoverTimer = setTimeout(() => {
            if (state === 'wave' || state === 'jump') return;
            const rect = card.getBoundingClientRect();
            const targetX = rect.left + rect.width / 2;
            const dir = posX + DRAW_W / 2 < targetX ? 'runR' : 'runL';
            state = dir; velX = dir === 'runR' ? 2.0 : -2.0; frame = 0; stateTimer = 100;
            showBubble(randQuip(CARD_QUIPS));
          }, 700);
        });
        card.addEventListener('mouseleave', () => clearTimeout(cardHoverTimer));
      });

      /* ---- hero avatar click → jump ---- */
      document.querySelector('.hero-avatar')?.addEventListener('click',e=>{
        e.stopPropagation();state='jump';velX=0;frame=0;stateTimer=60;
        showBubble(randQuip(JUMP_QUIPS));
      });

      /* ---- Konami code ---- */
      const KONAMI=['ArrowUp','ArrowUp','ArrowDown','ArrowDown','ArrowLeft','ArrowRight','ArrowLeft','ArrowRight','KeyB','KeyA'];
      let kIdx=0;
      document.addEventListener('keydown',e=>{
        if(e.code===KONAMI[kIdx]){kIdx++;if(kIdx===KONAMI.length){kIdx=0;let n=0;const t=setInterval(()=>{const ss=['runR','runL','jump','wave'];state=ss[n%ss.length];velX=state==='runR'?3.5:state==='runL'?-3.5:0;frame=0;stateTimer=18;showBubble('コナミコマンド！');if(++n>18)clearInterval(t);},280);}}else{kIdx=0;}
      });
    })();
    </script>
    <script>
    (() => {
      const API = 'https://feedback.tnks1407.com';
      const overlay = document.getElementById('fb-overlay');
      let selectedType = 'バグ報告';

      function relTime(iso) {
        const d = (Date.now() - new Date(iso)) / 1000;
        if (d < 60) return 'たった今';
        if (d < 3600) return Math.floor(d/60) + '分前';
        if (d < 86400) return Math.floor(d/3600) + '時間前';
        return Math.floor(d/86400) + '日前';
      }

      function badgeClass(type) {
        if (type === 'バグ報告') return 'bug';
        if (type === '機能の要望') return 'feat';
        return 'other';
      }

      function loadComments() {
        fetch(API + '/list')
          .then(r => r.json())
          .then(list => {
            const wrap = document.getElementById('fb-comments');
            const el = document.getElementById('fb-comment-list');
            if (!list.length) { wrap.style.display = 'none'; return; }
            el.innerHTML = list.map(c => `
              <div class="fb-comment-card">
                <div class="fb-comment-top">
                  <span class="fb-comment-badge ${badgeClass(c.type)}">${c.type}</span>
                  <span class="fb-comment-ts">${relTime(c.ts)}</span>
                </div>
                <div class="fb-comment-msg">${c.message.replace(/</g,'&lt;')}</div>
              </div>`).join('');
            wrap.style.display = '';
          })
          .catch(() => {});
      }

      function openFb() {
        document.getElementById('fb-form-wrap').style.display = '';
        document.getElementById('fb-thanks-wrap').style.display = 'none';
        overlay.classList.add('open');
        loadComments();
      }
      function closeFb() { overlay.classList.remove('open'); }
      document.getElementById('fb-open-btn').addEventListener('click', openFb);
      document.getElementById('fb-close-btn').addEventListener('click', closeFb);
      overlay.addEventListener('click', e => { if (e.target === overlay) closeFb(); });
      document.querySelectorAll('.fb-type-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.fb-type-btn').forEach(b => b.classList.remove('sel'));
          btn.classList.add('sel');
          selectedType = btn.dataset.type;
        });
      });
      document.getElementById('fb-submit').addEventListener('click', () => {
        const msg = document.getElementById('fb-msg').value.trim();
        if (!msg) { document.getElementById('fb-msg').focus(); return; }
        const contact = document.getElementById('fb-contact').value.trim();
        const btn = document.getElementById('fb-submit');
        btn.disabled = true;
        fetch(API + '/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: selectedType, message: msg, contact }),
        })
          .then(r => { if (r.status === 429) throw new Error('rate'); if (!r.ok) throw new Error(); })
          .then(() => {
            document.getElementById('fb-msg').value = '';
            document.getElementById('fb-contact').value = '';
            document.getElementById('fb-form-wrap').style.display = 'none';
            document.getElementById('fb-thanks-wrap').style.display = '';
            loadComments();
            setTimeout(closeFb, 3000);
          })
          .catch(e => {
            btn.disabled = false;
            alert(e.message === 'rate'
              ? 'しばらく間を置いてから送ってね（10分あたり3件まで）。'
              : '送信に失敗しました。もう一度試してね。');
          });
      });
      document.addEventListener('keydown', e => { if (e.key === 'Escape') closeFb(); });
    })();
    </script>
    <script>
    (() => {
      const activeTags = new Set();
      function updateFilter() {
        const cards = document.querySelectorAll('.work-card');
        const filterBar = document.getElementById('filter-bar');
        cards.forEach(card => {
          if (activeTags.size === 0) {
            card.classList.remove('dimmed');
          } else {
            const cardTags = card.dataset.tags ? card.dataset.tags.split(',') : [];
            const matches = [...activeTags].some(t => cardTags.includes(t));
            card.classList.toggle('dimmed', !matches);
          }
        });
        document.querySelectorAll('.tag').forEach(tag => {
          tag.classList.toggle('active', activeTags.has(tag.textContent.trim()));
        });
        filterBar.innerHTML = '';
        if (activeTags.size > 0) {
          activeTags.forEach(tag => {
            const chip = document.createElement('button');
            chip.className = 'filter-chip';
            chip.innerHTML = tag + ' <span>×</span>';
            chip.addEventListener('click', () => { activeTags.delete(tag); updateFilter(); });
            filterBar.appendChild(chip);
          });
          const clearBtn = document.createElement('button');
          clearBtn.className = 'filter-clear';
          clearBtn.textContent = 'clear all';
          clearBtn.addEventListener('click', () => { activeTags.clear(); updateFilter(); });
          filterBar.appendChild(clearBtn);
          const visible = [...cards].filter(c => !c.classList.contains('dimmed')).length;
          const countEl = document.createElement('span');
          countEl.className = 'filter-count';
          countEl.textContent = visible + ' / ' + cards.length;
          filterBar.appendChild(countEl);
        }
      }
      document.querySelectorAll('.tag').forEach(tag => {
        tag.addEventListener('click', e => {
          e.stopPropagation();
          const t = tag.textContent.trim();
          activeTags.has(t) ? activeTags.delete(t) : activeTags.add(t);
          updateFilter();
        });
      });
    })();
    </script>
    <script>
    (() => {
      const cv=document.createElement('canvas');
      cv.style.cssText='position:fixed;inset:0;pointer-events:none;z-index:998;';
      document.body.appendChild(cv);
      const ctx=cv.getContext('2d');
      const resize=()=>{cv.width=window.innerWidth;cv.height=window.innerHeight;};
      resize();window.addEventListener('resize',resize);
      const pts=[];
      const cols=['#3c7876','#5a9e9b','#8bc4c1','#8c6d4f','#c4a882','#e3dbd0'];
      window.addEventListener('mousemove',e=>{
        if(Math.random()>0.45)return;
        pts.push({x:e.clientX,y:e.clientY,vx:(Math.random()-0.5)*1.8,vy:(Math.random()-0.5)*1.8-0.8,
          life:1,size:Math.random()*3+1.5,col:cols[Math.floor(Math.random()*cols.length)]});
      });
      (function loop(){
        ctx.clearRect(0,0,cv.width,cv.height);
        for(let i=pts.length-1;i>=0;i--){
          const p=pts[i];p.life-=0.045;p.x+=p.vx;p.y+=p.vy;p.vy+=0.06;
          if(p.life<=0){pts.splice(i,1);continue;}
          ctx.globalAlpha=p.life*0.8;ctx.fillStyle=p.col;
          ctx.beginPath();ctx.arc(p.x,p.y,p.size*p.life,0,Math.PI*2);ctx.fill();
        }
        ctx.globalAlpha=1;requestAnimationFrame(loop);
      })();
    })();
    </script>
  </body>
</html>
