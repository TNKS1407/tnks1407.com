const works: Work[] = [
  {
    title: "運動方程式ラボ — Equation of Motion Lab",
    icon: "🪐",
    description: "式を1本足すたびに「まだ決まらない量」が減っていく。必要十分な式が揃った瞬間、自由度がゼロになって運動が一意に確定する――その過程を連立ソルバ＋canvasで可視化。束縛条件を外すと「ひもが伸びる運動」すら式の上では正解になってしまうことも確かめられる。",
    url: "https://eom.tnks1407.com",
    tags: ["JavaScript", "Canvas", "古典力学", "連立方程式"],
    status: "Single Crystal", section: "lab", group: "engineering",
  },
  {
    title: "反応拡散ラボ — Reaction-Diffusion",
    icon: "🧫",
    description: "Gray-Scottモデルの反応拡散をGPU(WebGL2)で高解像度・実時間にシミュレート。マウスで種を撒くと、縞・斑点・迷路・珊瑚のような模様が自分で育つ。F(餌)とk(分解)のスライダー＋プリセットで、同じ仕組みが全く違うパターンに化ける。",
    url: "https://rd.tnks1407.com",
    tags: ["WebGL2", "GPU", "Reaction-Diffusion", "Generative"],
    status: "Annealing", section: "lab", group: "engineering",
