    <main>
      <div class="hero">
        <canvas class="hero-bg" id="hero-bg" aria-hidden="true"></canvas>
        <div class="hero-body">
          <div class="hero-avatar" title="ランキン"></div>
          <div class="hero-text">
            <div class="hero-name">TNKS<span>1407</span></div>
