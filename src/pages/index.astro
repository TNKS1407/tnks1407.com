---
type Work = { title: string; description: string; url: string; tags: string[]; links?: { label: string; url: string }[]; icon?: string };

const quickLinks = [
  { label: "tnkblog.net", url: "https://tnkblog.net", icon: "📝" },
  { label: "nico.tnks1407.com", url: "https://nico.tnks1407.com", icon: "💬" },
  { label: "vg.tnks1407.com", url: "https://vg.tnks1407.com", icon: "🌀" },
  { label: "events.tnks1407.com", url: "https://events.tnks1407.com", icon: "📊" },
  { label: "seigou.tnks1407.com", url: "https://seigou.tnks1407.com", icon: "📡" },
  { label: "GitHub", url: "https://github.com/TNKS1407", icon: "⚙" },
];

const works: Work[] = [
  {
    title: "Nico Comment System",
    icon: "💬",
    description: "プレゼン・配信画面にリアルタイムでコメントを流すニコニコ風オーバーレイシステム。外部依存ゼロのNode.js製。",
    url: "https://nico.tnks1407.com",
    tags: ["Node.js", "SSE", "Self-host"],
    links: [
      { label: "投稿", url: "https://nico.tnks1407.com/p/A7kP3dQ9" },
      { label: "画面", url: "https://nico.tnks1407.com/s/A7kP3dQ9" },
      { label: "管理", url: "https://nico.tnks1407.com/admin" },
      { label: "QR", url: "https://nico.tnks1407.com/q/A7kP3dQ9" },
    ]
  },
  {
    title: "VG Generator",
    icon: "🌀",
    description: "ボルテックスジェネレーターSTLをブラウザで生成。スライダーでパラメータ調整、3Dプレビュー付き、そのまま3Dプリント可能。",
    url: "https://vg.tnks1407.com",
    tags: ["JavaScript", "3D Print", "STL"]
  },
  {
    title: "イベント会計",
    icon: "📊",
    description: "幹事がブラウザで割り勘計算・回収状況を管理し、参加者と公開URLで共有できるツール。ExcelもPythonも不要。",
    url: "https://events.tnks1407.com",
    tags: ["Node.js", "LocalStorage"],
    links: [
      { label: "幹事ページ", url: "https://events.tnks1407.com/admin" },
      { label: "参加者ページ", url: "https://events.tnks1407.com" },
    ]
  },
  {
    title: "SEIGOU — RFマッチング",
    icon: "📡",
    description: "RFインピーダンス整合回路をブラウザで計算・設計するツール。L・π・T型回路に対応、スミスチャート表示付き。",
    url: "https://seigou.tnks1407.com",
    tags: ["JavaScript", "RF", "Impedance Matching"]
  },
  {
    title: "Vortex Generator Tools",
    icon: "🔧",
    description: "rect・delta形状のVG STLを生成するPythonスクリプト。numpy・trimeshのみで動作、サンプルSTL付き。",
    url: "https://github.com/TNKS1407/vortex-generator-tools",
    tags: ["Python", "trimesh", "3D Print"]
  },
  {
    title: "tnks-lab",
    icon: "🧪",
    description: "AI実験・雑メモをGitHub Issueに自動変換する個人用ラボツール。PowerShell製UIランチャー付き。",
    url: "https://github.com/TNKS1407/tnks-lab",
    tags: ["PowerShell", "GitHub API", "CLI"]
  },
];

const docs: { title: string; description: string; url: string }[] = [];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="TNKS1407のアプリ・ツール・文書" />
    <link rel="icon" href="/favicon.ico" />
    <title>TNKS1407</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg:#fdf6fb;--surface:#fff0f8;--surface2:#fce8f4;
        --border:#f0c8e0;--accent1:#c87ec0;--accent2:#e86fa0;
        --accent3:#5bbfb0;--text:#3d2848;--text-muted:#9a7aaa;
        --shadow:rgba(200,126,192,0.12);
      }
      *{margin:0;padding:0;box-sizing:border-box;}
      html{scroll-behavior:smooth;}
      body{font-family:'Nunito',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;}

      /* Header */
      header{
        position:sticky;top:0;z-index:100;
        background:rgba(253,246,251,0.92);backdrop-filter:blur(12px);
        border-bottom:1.5px solid var(--border);
      }
      .header-inner{
        max-width:900px;margin:0 auto;height:52px;
        display:flex;align-items:center;justify-content:space-between;padding:0 1.25rem;
      }
      .logo{
        font-size:1.1rem;font-weight:800;
        background:linear-gradient(90deg,var(--accent1),var(--accent2));
        -webkit-background-clip:text;-webkit-text-fill-color:transparent;
      }
      .nav-links{display:flex;gap:0.25rem;}
      .nav-links a{
        padding:0.35rem 0.6rem;color:var(--text-muted);text-decoration:none;
        font-size:0.82rem;font-weight:700;border-radius:6px;transition:color 0.15s,background 0.15s;
      }
      .nav-links a:hover{color:var(--accent1);background:rgba(200,126,192,0.08);}

      /* Main */
      main{max-width:900px;margin:0 auto;padding:2rem 1.25rem 5rem;}

      /* Hero */
      .hero{
        background:linear-gradient(135deg,#fff0f8 0%,#fce8f4 50%,#edf8f6 100%);
        border:1.5px solid var(--border);border-radius:20px;
        padding:2.5rem 2rem;margin-bottom:2rem;
        position:relative;overflow:hidden;
        box-shadow:0 4px 24px var(--shadow);
      }
      .hero-grid{
        position:absolute;inset:0;
        background-image:linear-gradient(var(--border) 1px,transparent 1px),
          linear-gradient(90deg,var(--border) 1px,transparent 1px);
        background-size:32px 32px;opacity:0.35;
        mask-image:radial-gradient(ellipse at 70% 50%,black 30%,transparent 70%);
      }
      .hero-body{position:relative;z-index:1;display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap;}
      .hero-avatar{
        width:72px;height:72px;border-radius:50%;flex-shrink:0;
        background:linear-gradient(135deg,var(--accent1),var(--accent2));
        display:flex;align-items:center;justify-content:center;
        font-size:1.75rem;font-weight:800;color:#fff;
        box-shadow:0 4px 20px var(--shadow);border:3px solid rgba(255,255,255,0.5);
      }
      .hero-text{flex:1;min-width:0;}
      .hero-name{
        font-size:clamp(1.75rem,5vw,2.5rem);font-weight:800;line-height:1;
        background:linear-gradient(90deg,var(--accent1),var(--accent2),var(--accent3));
        -webkit-background-clip:text;-webkit-text-fill-color:transparent;
        margin-bottom:0.4rem;
      }
      .hero-desc{font-size:0.9rem;color:var(--text-muted);margin-bottom:0.75rem;}
      .hero-badges{display:flex;gap:0.4rem;flex-wrap:wrap;}
      .hero-badge{
        background:rgba(255,255,255,0.8);border:1px solid var(--border);
        padding:0.2rem 0.6rem;border-radius:999px;
        font-size:0.72rem;font-weight:700;color:var(--accent1);
        font-family:'JetBrains Mono',monospace;
      }

      /* Quick links */
      .quick-links{
        display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:2rem;
        padding:1rem 1.25rem;
        background:#fff;border:1.5px solid var(--border);border-radius:16px;
        box-shadow:0 2px 12px var(--shadow);
      }
      .quick-link{
        display:flex;align-items:center;gap:0.35rem;
        padding:0.35rem 0.75rem;border-radius:8px;
        background:var(--surface);border:1.5px solid var(--border);
        text-decoration:none;color:var(--text-muted);
        font-size:0.78rem;font-weight:700;font-family:'JetBrains Mono',monospace;
        transition:border-color 0.15s,color 0.15s;
      }
      .quick-link:hover{border-color:var(--accent1);color:var(--accent1);}
      .quick-link .icon{font-size:0.9rem;}

      /* Section */
      .section-title{
        font-size:0.78rem;font-weight:800;color:var(--text-muted);
        margin-bottom:0.75rem;letter-spacing:0.06em;
        display:flex;align-items:center;gap:0.5rem;
      }
      .section-title::after{content:'';flex:1;height:1px;background:var(--border);}

      /* Works grid */
      .works-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;margin-bottom:2rem;}
      .work-card{
        background:#fff;border:1.5px solid var(--border);border-radius:16px;overflow:hidden;
        box-shadow:0 2px 12px var(--shadow);
        transition:border-color 0.15s,transform 0.15s,box-shadow 0.15s;
      }
      .work-card:hover{border-color:var(--accent1);transform:translateY(-3px);box-shadow:0 6px 20px var(--shadow);}
      .work-main{display:block;padding:1.25rem;text-decoration:none;color:var(--text);}
      .work-icon-title{display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem;}
      .work-icon{font-size:1.1rem;}
      .work-title{font-size:0.95rem;font-weight:800;}
      .work-desc{font-size:0.82rem;color:var(--text-muted);line-height:1.55;margin-bottom:0.75rem;}
      .work-tags{display:flex;gap:0.3rem;flex-wrap:wrap;}
      .tag{
        background:var(--surface2);border:1px solid var(--border);
        color:var(--accent1);padding:0.1rem 0.45rem;border-radius:4px;
        font-size:0.7rem;font-weight:700;font-family:'JetBrains Mono',monospace;
      }
      .work-links{
        display:flex;gap:0.35rem;flex-wrap:wrap;
        padding:0.6rem 1.25rem;border-top:1px solid var(--border);background:var(--surface);
      }
      .work-link{
        color:var(--accent1);font-size:0.72rem;font-weight:700;
        text-decoration:none;font-family:'JetBrains Mono',monospace;
        padding:0.1rem 0.45rem;background:rgba(200,126,192,0.08);
        border-radius:4px;border:1px solid rgba(200,126,192,0.2);
        transition:background 0.15s;
      }
      .work-link:hover{background:rgba(200,126,192,0.18);}

      /* Empty */
      .empty{
        text-align:center;padding:2.5rem;
        background:#fff;border:2px dashed var(--border);border-radius:16px;color:var(--text-muted);
      }

      /* Footer */
      footer{
        border-top:1px solid var(--border);padding:1.5rem;text-align:center;
        color:var(--text-muted);font-size:0.78rem;background:var(--surface);
      }
      footer a{color:var(--accent1);text-decoration:none;}

      @media(max-width:480px){
        .hero-avatar{width:56px;height:56px;font-size:1.4rem;}
        .quick-link{font-size:0.7rem;}
      }
    </style>
  </head>
  <body>
    <header>
      <div class="header-inner">
        <span class="logo">TNKS1407</span>
        <nav class="nav-links">
          <a href="#works">Works</a>
          {docs.length > 0 && <a href="#docs">Docs</a>}
          <a href="https://tnkblog.net" target="_blank">Blog ↗</a>
          <a href="https://github.com/TNKS1407" target="_blank">GitHub ↗</a>
        </nav>
      </div>
    </header>

    <main>
      <!-- Hero -->
      <div class="hero">
        <div class="hero-grid"></div>
        <div class="hero-body">
          <div class="hero-avatar">T</div>
          <div class="hero-text">
            <div class="hero-name">TNKS1407</div>
            <div class="hero-desc">アプリ・ツール・文書を作っています</div>
            <div class="hero-badges">
              <span class="hero-badge">Developer</span>
              <span class="hero-badge">Creator</span>
              <span class="hero-badge">Tinkerer</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Quick links -->
      <div class="quick-links">
        {quickLinks.map(l => (
          <a href={l.url} class="quick-link" target="_blank" rel="noopener">
            <span class="icon">{l.icon}</span>
            {l.label}
          </a>
        ))}
      </div>

      <!-- Works -->
      <div id="works">
        <div class="section-title">WORKS</div>
        <div class="works-grid">
          {works.map(w => (
            <div class="work-card">
              <a href={w.url} class="work-main" target="_blank" rel="noopener">
                <div class="work-icon-title">
                  <span class="work-icon">{w.icon}</span>
                  <span class="work-title">{w.title}</span>
                </div>
                <div class="work-desc">{w.description}</div>
                <div class="work-tags">
                  {w.tags.map(t => <span class="tag">{t}</span>)}
                </div>
              </a>
              {w.links && (
                <div class="work-links">
                  {w.links.map(l => (
                    <a href={l.url} class="work-link" target="_blank" rel="noopener">{l.label} ↗</a>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      </div>

      <!-- Docs -->
      {docs.length > 0 && (
        <div id="docs">
          <div class="section-title">DOCUMENTS</div>
          <div class="works-grid">
            {docs.map(d => (
              <a href={d.url} class="work-card work-main" target="_blank" rel="noopener">
                <div class="work-title">{d.title}</div>
                <div class="work-desc">{d.description}</div>
              </a>
            ))}
          </div>
        </div>
      )}
    </main>

    <footer>
      © 2025 TNKS1407 ·
      <a href="https://github.com/TNKS1407" target="_blank">GitHub</a> ·
      <a href="https://tnkblog.net" target="_blank">Blog</a>
    </footer>

    <!-- Tinks roaming sprite -->
    <canvas id="tinks" style="position:fixed;bottom:0;left:0;pointer-events:none;z-index:999;image-rendering:pixelated;image-rendering:crisp-edges;"></canvas>
    <div id="tinks-bubble" style="position:fixed;bottom:0;left:0;pointer-events:none;z-index:1000;display:none;
      background:#fff;border:2px solid #f0c8e0;border-radius:12px 12px 12px 2px;
      padding:0.4rem 0.75rem;font-family:'Nunito',sans-serif;font-size:0.8rem;font-weight:700;
      color:#3d2848;white-space:nowrap;box-shadow:0 2px 12px rgba(200,126,192,0.15);"></div>

    <script>
    (() => {
      const SHEET_URL = 'https://raw.githubusercontent.com/TNKS1407/shinku-tinks/master/spritesheet.webp';
      const CW = 192, CH = 208, COLS = 8;
      const getScale = () => window.innerWidth < 480 ? 1 : window.innerWidth < 768 ? 1.5 : 2;
      let SCALE = getScale();
      let DRAW_W = CW * SCALE, DRAW_H = CH * SCALE;
      const STATES = {
        idle:{row:0,frames:6},runR:{row:1,frames:8},runL:{row:2,frames:8},
        wave:{row:3,frames:4},jump:{row:4,frames:5},wait:{row:6,frames:6},run:{row:7,frames:6},
      };
      const QUIPS = ['よろしくね！','準備中…','ランキンのブログ見てね','ふむ…','なにかお手伝いを','…','コードは詩だよ'];
      const canvas = document.getElementById('tinks');
      function resizeCanvas(){SCALE=getScale();DRAW_W=CW*SCALE;DRAW_H=CH*SCALE;canvas.width=DRAW_W;canvas.height=DRAW_H;}
      resizeCanvas();
      const ctx=canvas.getContext('2d');
      const bubble=document.getElementById('tinks-bubble');
      const off=document.createElement('canvas');off.width=CW;off.height=CH;
      const offCtx=off.getContext('2d');
      const img=new Image();img.crossOrigin='anonymous';img.src=SHEET_URL;
      let posX=40,velX=0.8,state='idle',frame=0,stateTimer=0;
      const FPS=8,FRAME_MS=1000/FPS;
      function chromaKey(d){for(let i=0;i<d.length;i+=4)if(d[i]>200&&d[i+1]<80&&d[i+2]>200)d[i+3]=0;}
      function drawSprite(){
        const s=STATES[state];
        offCtx.clearRect(0,0,CW,CH);
        offCtx.drawImage(img,(frame%COLS)*CW,s.row*CH,CW,CH,0,0,CW,CH);
        const d=offCtx.getImageData(0,0,CW,CH);chromaKey(d.data);offCtx.putImageData(d,0,0);
        ctx.clearRect(0,0,DRAW_W,DRAW_H);ctx.imageSmoothingEnabled=false;
        ctx.drawImage(off,0,0,DRAW_W,DRAW_H);
      }
      function positionCanvas(){
        const maxX=window.innerWidth-DRAW_W;
        posX=Math.max(0,Math.min(maxX,posX));
        canvas.style.left=posX+'px';canvas.style.bottom='0px';
        bubble.style.left=(posX+DRAW_W*0.1)+'px';bubble.style.bottom=(DRAW_H+8)+'px';
      }
      function showBubble(){
        bubble.textContent=QUIPS[Math.floor(Math.random()*QUIPS.length)];
        bubble.style.display='block';
        setTimeout(()=>{bubble.style.display='none';},2500);
      }
      function pickState(){
        const r=Math.random();
        if(r<0.35){state='runR';velX=1.2;}
        else if(r<0.7){state='runL';velX=-1.2;}
        else if(r<0.82){state='wave';velX=0;showBubble();}
        else if(r<0.9){state='jump';velX=0;}
        else{state='idle';velX=0;}
        stateTimer=120+Math.random()*180;frame=0;
      }
      let lastTs=0;
      function tick(ts){
        if(!img.complete){requestAnimationFrame(tick);return;}
        if(ts-lastTs>FRAME_MS){
          frame=(frame+1)%STATES[state].frames;
          posX+=velX;
          const maxX=window.innerWidth-DRAW_W;
          if(posX<=0){posX=0;velX=Math.abs(velX);state='runR';frame=0;}
          if(posX>=maxX){posX=maxX;velX=-Math.abs(velX);state='runL';frame=0;}
          if(--stateTimer<=0)pickState();
          drawSprite();positionCanvas();lastTs=ts;
        }
        requestAnimationFrame(tick);
      }
      img.onload=()=>{posX=Math.random()*(window.innerWidth-DRAW_W*2)+DRAW_W;pickState();requestAnimationFrame(tick);};
      window.addEventListener('resize',()=>{resizeCanvas();positionCanvas();});
    })();
    </script>
  </body>
</html>
