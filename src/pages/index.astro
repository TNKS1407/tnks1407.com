const uniqueTags = [...new Set(works.flatMap(w => w.tags))];

const GROUPS = [
  { key: 'engineering', label: 'Engineering', desc: 'RF・電力制御・電磁シミュレーション・CAD・データ可視化' },
  { key: 'data-lab',    label: 'Data Lab',    desc: 'プロセスデータのモデリングと画像処理の学習ラボ' },
  { key: 'utilities',   label: 'Utilities',   desc: 'プレゼン・イベント・ワークフロー管理の実用ツール' },
] as const;

// 各グループはこの数まで初期表示し、残りは「もっと見る」で展開する
const WORK_LIMIT = 6;

const grouped = Object.fromEntries(
  GROUPS.map(g => [g.key, works.filter(w => w.group === g.key)])
);

// お気に入りキー（作品ごと）: URLのサブドメイン名から w-<label> を作る（例: w-stepper）
const favKey = (w: Work) => {
  let label = '';
  try {
    const u = new URL(w.url);
    label = u.hostname.includes('github.com')
      ? (u.pathname.split('/').filter(Boolean).pop() || 'github')  // github はリポジトリ名で
      : u.hostname.split('.')[0];                                  // それ以外はサブドメイン名で
  } catch {}
  label = (label || 'x').toLowerCase().replace(/[^a-z0-9-]/g, '');
  return 'w-' + (label || 'x');
};

