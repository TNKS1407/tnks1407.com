            <span class="docs-teaser-title">見える物理を、触りながら一歩ずつ</span>
            <span class="docs-teaser-desc">力学の基礎 → 声と共鳴 → 足し合わせと保存で場を掴む。{explainers.length} 本の解説を読む順に並べ、この先（発散・ガウス・グリーン関数）まで見渡せる“地図”。</span>
          </div>
          <span class="docs-teaser-go">ロードマップを開く →</span>
        </a>
      )}

      <!-- Works by group -->
      <div id="works">
        <div class="filter-bar" id="filter-bar"></div>
        {GROUPS.map(g => (
          grouped[g.key].length > 0 && (
            <div class="group-wrap" data-group={g.key}>
              <div class="group-header">
                <span class="group-label">{g.label}</span>
                <span class="group-desc">{g.desc}</span>
              </div>
              <div class="works-grid">
                {grouped[g.key].map((w, i) => (
                  <div class={`work-card${i >= WORK_LIMIT ? ' work-extra' : ''}`} data-tags={w.tags.join(',')}>
                    <a href={w.url} class="work-main" target="_blank" rel="noopener noreferrer">
                      <div class="work-icon-title">
                        <span class="work-icon">{w.icon}</span>
                        <span class="work-title">{w.title}</span>
                      </div>
                      <div class="work-desc">{w.description}</div>
                      <div class="work-tags">
                        {w.status && <span class={`status-badge status-${w.status.replace(/\s+/g,'')}`}>{w.status}</span>}
                        {w.tags.map(t => <span class="tag">{t}</span>)}
                      </div>
                    </a>
                    <div class="work-footer">
                      <button class="fav-btn" data-fav={favKey(w)} type="button" aria-pressed="false" title="お気に入り（一人一回）">
                        <span class="star">☆</span><span class="fav-n">·</span>
                      </button>
                      {w.links?.map(l => (
                        <a href={l.url} class="work-link" target="_blank" rel="noopener noreferrer">{l.label} ↗</a>
                      ))}
                      <button class="preview-btn" data-url={w.url} data-title={w.title} onclick="window.openPreview(this)">
                        👁 preview
                      </button>
                      {w.prompt && (
                        <button class="prompt-btn" data-idx={String(works.indexOf(w))} onclick="window.openPrompt(this)">
                          📋 prompt
                        </button>
                      )}
                    </div>
                  </div>
                ))}
              </div>
              {grouped[g.key].length > WORK_LIMIT && (
                <button class="more-btn" type="button">もっと見る (+{grouped[g.key].length - WORK_LIMIT})</button>
              )}
