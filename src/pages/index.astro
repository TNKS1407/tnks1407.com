      <div class="preview-modal" onclick="event.stopPropagation()">
        <div class="preview-head">
          <span class="preview-title" id="preview-title"></span>
          <a class="preview-open" id="preview-open" href="#" target="_blank" rel="noopener noreferrer">新しいタブで開く ↗</a>
          <button class="modal-close" onclick="window.closePreview()">✕</button>
        </div>
        <div class="preview-frame-wrap">
          <div class="preview-loading" id="preview-loading">読み込み中…</div>
