      <!-- Recent blog posts -->
      <div class="blog-strip">
        <div class="blog-strip-head">
          <span class="blog-strip-title">最近の記事 — tnkblog.net</span>
          <a href="https://tnkblog.net" class="blog-strip-link" target="_blank" rel="noopener noreferrer">すべて見る ↗</a>
        </div>
        <div class="blog-posts" id="blog-posts">
          <span class="blog-loading">読み込み中…</span>
