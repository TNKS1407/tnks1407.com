---
const works: { title: string; description: string; url: string; tags: string[] }[] = [
  {
    title: "Nico Comment System",
    description: "プレゼン・配信画面にリアルタイムでコメントを流すニコニコ風オーバーレイシステム。管理パネル、QRコードオーバーレイ対応。外部ライブラリ不要。",
    url: "https://nico.tnks1407.com",
    tags: ["Node.js", "SSE", "Self-host"]
  },
  {
    title: "Vortex Generator Tools",
    description: "パラメトリックなボルテックスジェネレーター（VG）STLファイルを生成するPythonスクリプト。rect・delta形状対応、3Dプリント用。",
    url: "https://github.com/TNKS1407/vortex-generator-tools",
    tags: ["Python", "trimesh", "3D Print"]
  },
  {
    title: "tnks-lab",
    description: "AI実験・雑メモをGitHub Issueに自動変換する個人用ラボツール。PowerShell製のUIランチャー付き。",
    url: "https://github.com/TNKS1407/tnks-lab",
    tags: ["PowerShell", "GitHub API", "CLI"]
  },
];

const docs: { title: string; description: string; url: string }[] = [
  // 例: { title: "レポート", description: "説明", url: "https://..." }
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Apps, tools & documents by TNKS1407" />
    <link rel="icon" href="/favicon.ico" />
    <title>TNKS1407</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg: #fdf6fb;
        --surface: #fff0f8;
        --surface2: #fce8f4;
        --border: #f0c8e0;
        --accent1: #c87ec0;
        --accent2: #e86fa0;
        --accent3: #5bbfb0;
        --text: #3d2848;
        --text-muted: #9a7aaa;
        --shadow: rgba(200,126,192,0.15);
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        font-family: 'Nunito', sans-serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        overflow-x: hidden;
      }

      /* Nav */
      nav {
        position: fixed; top: 0; left: 0; right: 0; z-index: 100;
        display: flex; align-items: center; justify-content: space-between;
        padding: 1rem 2rem;
        background: rgba(253,246,251,0.88);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
      }
      .nav-logo {
        font-size: 1.2rem; font-weight: 800;
        background: linear-gradient(90deg, var(--accent1), var(--accent2));
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      }
      .nav-links { display: flex; gap: 1.5rem; }
      .nav-links a {
        color: var(--text-muted); text-decoration: none;
        font-size: 0.9rem; font-weight: 700;
        transition: color 0.2s;
      }
      .nav-links a:hover { color: var(--accent1); }

      /* Hero */
      .hero {
        min-height: 100vh;
        display: flex; align-items: center; justify-content: center;
        text-align: center;
        position: relative;
        overflow: hidden;
        padding: 6rem 1rem 4rem;
      }
      .hero::before {
        content: '';
        position: absolute; inset: 0;
        background:
          radial-gradient(ellipse 60% 60% at 30% 40%, rgba(200,126,192,0.12) 0%, transparent 70%),
          radial-gradient(ellipse 50% 50% at 70% 60%, rgba(232,111,160,0.10) 0%, transparent 70%);
      }
      .grid-bg {
        position: absolute; inset: 0;
        background-image:
          linear-gradient(var(--border) 1px, transparent 1px),
          linear-gradient(90deg, var(--border) 1px, transparent 1px);
        background-size: 40px 40px;
        opacity: 0.5;
        mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%);
      }
      .hero-content { position: relative; z-index: 1; }
      .avatar {
        width: 100px; height: 100px; border-radius: 50%;
        margin: 0 auto 1.5rem;
        background: linear-gradient(135deg, var(--accent1), var(--accent2));
        display: flex; align-items: center; justify-content: center;
        font-size: 2.5rem; font-weight: 800; color: #fff;
        box-shadow: 0 8px 32px var(--shadow);
        border: 3px solid rgba(255,255,255,0.6);
      }
      h1 {
        font-size: clamp(2.5rem, 8vw, 5rem);
        font-weight: 800; letter-spacing: -0.02em; line-height: 1;
        margin-bottom: 1rem;
      }
      h1 .accent {
        background: linear-gradient(90deg, var(--accent1), var(--accent2), var(--accent3));
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      }
      .tagline {
        font-size: 1.1rem; color: var(--text-muted); margin-bottom: 1.5rem;
      }
      .badges { display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap; }
      .badge {
        background: #fff; border: 1px solid var(--border);
        padding: 0.25rem 0.75rem; border-radius: 999px;
        font-size: 0.8rem; font-weight: 700; color: var(--accent1);
        font-family: 'JetBrains Mono', monospace;
        box-shadow: 0 2px 8px var(--shadow);
      }
      .scroll-hint {
        position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%);
        color: var(--text-muted); font-size: 0.8rem; z-index: 1;
        animation: bounce 2s infinite;
      }
      @keyframes bounce { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(6px)} }

      /* Sections */
      section { padding: 5rem 1rem; max-width: 900px; margin: 0 auto; }
      .section-title {
        font-size: 1.75rem; font-weight: 800; margin-bottom: 2rem;
        display: flex; align-items: center; gap: 0.5rem;
      }
      .section-title .line {
        flex: 1; height: 2px;
        background: linear-gradient(90deg, var(--border), transparent);
        margin-left: 1rem; border-radius: 999px;
      }

      /* Cards */
      .card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem; }
      .card {
        background: #fff; border: 1.5px solid var(--border);
        border-radius: 16px; padding: 1.5rem;
        text-decoration: none; color: var(--text);
        transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
        display: block;
        box-shadow: 0 2px 12px var(--shadow);
      }
      .card:hover {
        border-color: var(--accent1);
        transform: translateY(-4px);
        box-shadow: 0 8px 24px var(--shadow);
      }
      .card-title { font-size: 1rem; font-weight: 800; margin-bottom: 0.5rem; }
      .card-desc { font-size: 0.875rem; color: var(--text-muted); margin-bottom: 1rem; line-height: 1.5; }
      .card-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }
      .tag {
        background: var(--surface2); border: 1px solid var(--border);
        color: var(--accent1); padding: 0.15rem 0.5rem; border-radius: 4px;
        font-size: 0.75rem; font-weight: 700; font-family: 'JetBrains Mono', monospace;
      }

      /* Empty state */
      .empty {
        text-align: center; padding: 3rem;
        background: #fff; border: 2px dashed var(--border);
        border-radius: 16px; color: var(--text-muted);
      }
      .empty-icon { font-size: 2rem; margin-bottom: 0.5rem; }

      /* Footer */
      footer {
        border-top: 1px solid var(--border);
        padding: 2rem; text-align: center;
        color: var(--text-muted); font-size: 0.8rem;
        background: var(--surface);
      }
      footer a { color: var(--accent1); text-decoration: none; }
    </style>
  </head>
  <body>
    <nav>
      <span class="nav-logo">TNKS1407</span>
      <div class="nav-links">
        <a href="#works">Works</a>
        <a href="#docs">Docs</a>
        <a href="https://tnkblog.net" target="_blank">Blog</a>
      </div>
    </nav>

    <div class="hero">
      <div class="grid-bg"></div>
      <div class="hero-content">
        <div class="avatar">T</div>
        <h1>TNKS<span class="accent">1407</span></h1>
        <p class="tagline">アプリ・ツール・文書を作っています</p>
        <div class="badges">
          <span class="badge">Developer</span>
          <span class="badge">Creator</span>
          <span class="badge">Tinkerer</span>
        </div>
      </div>
      <div class="scroll-hint">↓ scroll</div>
    </div>

    <section id="works">
      <h2 class="section-title">⚙ Works <span class="line"></span></h2>
      {works.length === 0 ? (
        <div class="empty">
          <div class="empty-icon">🚧</div>
          <p>準備中...</p>
        </div>
      ) : (
        <div class="card-grid">
          {works.map(w => (
            <a href={w.url} class="card" target="_blank" rel="noopener">
              <div class="card-title">{w.title}</div>
              <div class="card-desc">{w.description}</div>
              <div class="card-tags">
                {w.tags.map(t => <span class="tag">{t}</span>)}
              </div>
            </a>
          ))}
        </div>
      )}
    </section>

    <section id="docs">
      <h2 class="section-title">📄 Documents <span class="line"></span></h2>
      {docs.length === 0 ? (
        <div class="empty">
          <div class="empty-icon">🚧</div>
          <p>準備中...</p>
        </div>
      ) : (
        <div class="card-grid">
          {docs.map(d => (
            <a href={d.url} class="card" target="_blank" rel="noopener">
              <div class="card-title">{d.title}</div>
              <div class="card-desc">{d.description}</div>
            </a>
          ))}
        </div>
      )}
    </section>

    <footer>
      <p>© 2025 TNKS1407 · <a href="https://github.com/TNKS1407" target="_blank">GitHub</a> · <a href="https://tnkblog.net" target="_blank">Blog</a></p>
    </footer>

    <!-- Tinks roaming sprite -->
    <canvas id="tinks" style="position:fixed;bottom:0;left:0;pointer-events:none;z-index:999;image-rendering:pixelated;image-rendering:crisp-edges;"></canvas>
    <div id="tinks-bubble" style="position:fixed;bottom:0;left:0;pointer-events:none;z-index:1000;display:none;
      background:#fff;border:2px solid #f0c8e0;border-radius:12px 12px 12px 2px;
      padding:0.4rem 0.75rem;font-family:'Nunito',sans-serif;font-size:0.8rem;font-weight:700;
      color:#3d2848;white-space:nowrap;box-shadow:0 2px 12px rgba(200,126,192,0.15);"></div>

    <script>
    (() => {
      const SHEET_URL = 'https://raw.githubusercontent.com/TNKS1407/shinku-tinks/master/spritesheet.webp';
      const CW = 192, CH = 208, COLS = 8, SCALE = 2;
      const DRAW_W = CW * SCALE, DRAW_H = CH * SCALE;
      const STATES = {
        idle:   { row: 0, frames: 6 },
        runR:   { row: 1, frames: 8 },
        runL:   { row: 2, frames: 8 },
        wave:   { row: 3, frames: 4 },
        jump:   { row: 4, frames: 5 },
        wait:   { row: 6, frames: 6 },
        run:    { row: 7, frames: 6 },
      };
      const QUIPS = [
        'よろしくね！', '準備中…', 'ランキンのブログ見てね',
        'ふむ…', 'なにかお手伝いを', 'がんばるよ',
        '…', '考え中', 'コードは詩だよ',
      ];

      const canvas = document.getElementById('tinks');
      canvas.width = DRAW_W; canvas.height = DRAW_H;
      const ctx = canvas.getContext('2d');
      const bubble = document.getElementById('tinks-bubble');

      const off = document.createElement('canvas');
      off.width = CW; off.height = CH;
      const offCtx = off.getContext('2d');

      const img = new Image();
      img.crossOrigin = 'anonymous';
      img.src = SHEET_URL;

      let posX = 40, posY = 0;
      let velX = 0.8, state = 'idle', frame = 0;
      let stateTimer = 0, frameTimer = 0;
      const FPS = 8, FRAME_MS = 1000 / FPS;

      function chromaKey(data) {
        for (let i = 0; i < data.length; i += 4)
          if (data[i] > 200 && data[i+1] < 80 && data[i+2] > 200) data[i+3] = 0;
      }

      function drawSprite() {
        const s = STATES[state];
        offCtx.clearRect(0, 0, CW, CH);
        offCtx.drawImage(img, (frame % COLS) * CW, s.row * CH, CW, CH, 0, 0, CW, CH);
        const d = offCtx.getImageData(0, 0, CW, CH);
        chromaKey(d.data); offCtx.putImageData(d, 0, 0);
        ctx.clearRect(0, 0, DRAW_W, DRAW_H);
        ctx.imageSmoothingEnabled = false;
        ctx.drawImage(off, 0, 0, DRAW_W, DRAW_H);
      }

      function positionCanvas() {
        const maxX = window.innerWidth - DRAW_W;
        posX = Math.max(0, Math.min(maxX, posX));
        posY = window.innerHeight - DRAW_H;
        canvas.style.left = posX + 'px';
        canvas.style.bottom = '0px';
        bubble.style.left = (posX + DRAW_W * 0.1) + 'px';
        bubble.style.bottom = (DRAW_H + 8) + 'px';
      }

      function pickState() {
        const r = Math.random();
        if (r < 0.35) { state = 'runR'; velX = 1.2; }
        else if (r < 0.7) { state = 'runL'; velX = -1.2; }
        else if (r < 0.82) { state = 'wave'; velX = 0; showBubble(); }
        else if (r < 0.9) { state = 'jump'; velX = 0; }
        else { state = 'idle'; velX = 0; }
        stateTimer = 120 + Math.random() * 180;
        frame = 0;
      }

      function showBubble() {
        bubble.textContent = QUIPS[Math.floor(Math.random() * QUIPS.length)];
        bubble.style.display = 'block';
        setTimeout(() => { bubble.style.display = 'none'; }, 2500);
      }

      let lastTs = 0;
      function tick(ts) {
        if (!img.complete) { requestAnimationFrame(tick); return; }
        const dt = ts - lastTs;

        if (dt > FRAME_MS) {
          // Update frame
          frame = (frame + 1) % STATES[state].frames;
          // Move
          posX += velX;
          // Bounce
          const maxX = window.innerWidth - DRAW_W;
          if (posX <= 0) { posX = 0; velX = Math.abs(velX); state = 'runR'; frame = 0; }
          if (posX >= maxX) { posX = maxX; velX = -Math.abs(velX); state = 'runL'; frame = 0; }
          // State timer
          stateTimer--;
          if (stateTimer <= 0) pickState();

          drawSprite();
          positionCanvas();
          lastTs = ts;
        }
        requestAnimationFrame(tick);
      }

      img.onload = () => {
        posX = Math.random() * (window.innerWidth - DRAW_W * 2) + DRAW_W;
        pickState();
        requestAnimationFrame(tick);
      };

      window.addEventListener('resize', positionCanvas);
    })();
    </script>
  </body>
</html>
