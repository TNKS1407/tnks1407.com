      .tag{background:var(--surface2);border:1px solid var(--border);color:var(--text-muted);padding:0.08rem 0.4rem;border-radius:4px;font-size:0.68rem;font-weight:500;font-family:'JetBrains Mono',monospace;}
      .status-badge{padding:0.08rem 0.4rem;border-radius:4px;font-size:0.66rem;font-weight:700;font-family:'JetBrains Mono',monospace;border:1px solid;}
      /* 成熟度＝結晶化の進み具合。融液→核生成→焼鈍→単結晶 と進むほど整っている。 */
      .status-SingleCrystal{background:#eaf7f4;color:#0d7f6e;border-color:#9de0cf;}
      .status-Annealing{background:#fdf4eb;color:#b45e1a;border-color:#f5cfaa;}
      .status-Nucleation{background:#f3ece0;color:#9a7b43;border-color:#e2d3b8;}
      .status-Melt{background:#f4f1ec;color:#948b7c;border-color:#e3dbd0;}
      .work-footer{display:flex;gap:0.3rem;flex-wrap:wrap;padding:0.5rem 1.2rem 0.8rem;align-items:center;}
      .work-link{color:var(--accent);font-size:0.7rem;font-weight:600;text-decoration:none;font-family:'JetBrains Mono',monospace;padding:0.1rem 0.4rem;background:var(--accent-dim);border-radius:4px;border:1px solid rgba(60,120,118,0.18);transition:background 0.15s;}
      .work-link:hover{background:rgba(60,120,118,0.16);}
      .prompt-btn{margin-left:auto;font-size:0.68rem;font-weight:600;color:var(--text-faint);background:none;border:1px solid var(--border);border-radius:4px;padding:0.1rem 0.45rem;cursor:pointer;font-family:'JetBrains Mono',monospace;transition:color 0.15s,border-color 0.15s;}
      .prompt-btn:hover{color:var(--accent);border-color:var(--accent);}

      /* Modal */
      .modal-overlay{position:fixed;inset:0;background:rgba(29,27,23,0.45);z-index:200;display:flex;align-items:center;justify-content:center;padding:1rem;opacity:0;pointer-events:none;transition:opacity 0.2s;}
      .modal-overlay.open{opacity:1;pointer-events:all;}
      .modal{background:var(--card);border:1px solid var(--border);border-radius:18px;max-width:560px;width:100%;max-height:80vh;overflow:hidden;box-shadow:0 20px 56px var(--shadow-md);display:flex;flex-direction:column;}
      .modal-header{padding:1rem 1.25rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
      .modal-title{font-size:0.88rem;font-weight:700;color:var(--text);}
      .modal-close{background:none;border:none;cursor:pointer;font-size:1.1rem;color:var(--text-muted);line-height:1;}
      .modal-body{padding:1.25rem;overflow-y:auto;flex:1;}
      .modal-body pre{font-family:'JetBrains Mono',monospace;font-size:0.77rem;line-height:1.7;color:var(--text);white-space:pre-wrap;word-break:break-word;background:var(--surface2);border-radius:10px;padding:1rem;}

      /* Preview button + modal */
      .preview-btn{font-size:0.68rem;font-weight:600;color:var(--text-faint);background:none;border:1px solid var(--border);border-radius:4px;padding:0.1rem 0.45rem;cursor:pointer;font-family:'JetBrains Mono',monospace;transition:color 0.15s,border-color 0.15s;}
      .preview-btn:hover{color:var(--accent);border-color:var(--accent);}
      .work-footer .preview-btn{margin-left:auto;}
      .work-footer .preview-btn + .prompt-btn{margin-left:0.3rem;}
      .fav-btn{display:inline-flex;align-items:center;gap:0.25rem;font-size:0.68rem;font-weight:600;color:var(--text-faint);background:none;border:1px solid var(--border);border-radius:4px;padding:0.1rem 0.45rem;cursor:pointer;font-family:'JetBrains Mono',monospace;transition:color 0.15s,border-color 0.15s,background 0.15s;}
      .fav-btn:hover{color:var(--accent);border-color:var(--accent);}
      .fav-btn.faved{color:var(--accent);border-color:var(--accent);background:var(--accent-dim);cursor:default;}
      .fav-btn.faved .star{color:#e8b339;}
      .fav-btn .star{font-size:0.85rem;line-height:1;}
      .preview-modal{background:var(--card);border:1px solid var(--border);border-radius:16px;width:100%;max-width:1040px;height:86vh;max-height:860px;overflow:hidden;box-shadow:0 20px 56px var(--shadow-md);display:flex;flex-direction:column;}
      .preview-head{padding:0.7rem 1rem;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:0.75rem;}
      .preview-title{font-size:0.85rem;font-weight:700;color:var(--text);flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
      .preview-open{font-size:0.72rem;font-weight:600;color:var(--accent);text-decoration:none;font-family:'JetBrains Mono',monospace;padding:0.18rem 0.55rem;background:var(--accent-dim);border-radius:6px;border:1px solid rgba(60,120,118,0.18);white-space:nowrap;}
      .preview-open:hover{background:rgba(60,120,118,0.16);}
      .preview-frame-wrap{flex:1;position:relative;background:var(--surface2);}
      .preview-frame-wrap iframe{position:absolute;inset:0;width:100%;height:100%;border:0;background:#fff;}
      .preview-loading{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:var(--text-faint);font-size:0.8rem;font-family:'JetBrains Mono',monospace;}

      footer{border-top:1px solid var(--border);padding:1.5rem;text-align:center;color:var(--text-faint);font-size:0.75rem;background:var(--surface);}
      footer a{color:var(--text-muted);text-decoration:none;transition:color 0.15s;}
      footer a:hover{color:var(--accent);}
      .footer-credit{margin-top:0.35rem;font-size:0.68rem;color:var(--text-faint);font-family:'JetBrains Mono',monospace;}

      /* Tag filter */
      .tag{cursor:pointer;user-select:none;transition:background 0.15s,color 0.15s,border-color 0.15s;}
      .tag:hover,.tag.active{background:var(--accent);color:#fff;border-color:var(--accent);}
      .work-card.dimmed{opacity:0.1;transform:scale(0.97);pointer-events:none;}
      .filter-bar{display:flex;align-items:center;gap:0.4rem;flex-wrap:wrap;margin-bottom:0.75rem;min-height:1.6rem;}
      .filter-chip{display:inline-flex;align-items:center;gap:0.2rem;background:var(--accent);color:#fff;border:none;border-radius:999px;padding:0.2rem 0.65rem;font-size:0.7rem;font-weight:600;font-family:'JetBrains Mono',monospace;cursor:pointer;transition:opacity 0.15s;}
      .filter-chip:hover{opacity:0.85;}
      .filter-clear{background:none;border:1px solid var(--border);border-radius:6px;padding:0.2rem 0.5rem;font-size:0.7rem;color:var(--text-muted);cursor:pointer;font-family:'JetBrains Mono',monospace;transition:color 0.15s,border-color 0.15s;}
      .filter-clear:hover{border-color:var(--accent);color:var(--accent);}
      .filter-count{margin-left:auto;font-size:0.7rem;color:var(--text-faint);font-family:'JetBrains Mono',monospace;}

      /* 改善を送るボタンは src/components/ImproveButton.astro（scoped）に分離 */

      /* Group headers */
      .group-header{display:flex;align-items:baseline;gap:0.75rem;margin:2.25rem 0 0.9rem;}
      .group-label{font-family:'JetBrains Mono',monospace;font-size:.72rem;font-weight:700;
        color:var(--text-faint);letter-spacing:.1em;text-transform:uppercase;}
      .group-label::before{content:'// ';color:var(--accent);opacity:.6;}
      .group-desc{font-size:.78rem;color:var(--text-faint);}
      .group-header::after{content:'';flex:1;height:1px;background:var(--border);}
      /* Works: 初期は WORK_LIMIT 件、残りは「もっと見る」で展開（フィルタ時は自動展開） */
      .group-wrap{position:relative;}
      .work-extra{display:none;}
      .group-wrap.expanded .work-extra,.group-wrap.filtering .work-extra{display:block;}
      .more-btn{display:block;margin:1rem auto 0;font-family:'JetBrains Mono',monospace;font-size:0.74rem;font-weight:600;color:var(--text-muted);background:var(--card);border:1px solid var(--border);border-radius:999px;padding:0.4rem 1.15rem;cursor:pointer;transition:border-color 0.15s,color 0.15s;}
      .more-btn:hover{border-color:var(--accent);color:var(--accent);}
      .group-wrap.expanded .more-btn,.group-wrap.filtering .more-btn{display:none;}

      /* Recent blog posts */
      .blog-strip{background:var(--card);border:1px solid var(--border);border-radius:14px;
        padding:1.1rem 1.25rem;margin-bottom:2rem;box-shadow:0 1px 6px var(--shadow);}
      .blog-strip-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:.9rem;}
      .blog-strip-title{font-family:'JetBrains Mono',monospace;font-size:.7rem;font-weight:700;
        color:var(--text-faint);letter-spacing:.1em;text-transform:uppercase;}
      .blog-strip-link{font-size:.72rem;color:var(--accent);font-family:'JetBrains Mono',monospace;text-decoration:none;}
      .blog-strip-link:hover{text-decoration:underline;}
      .blog-posts{display:flex;flex-direction:column;gap:.5rem;}
      .blog-post-item{display:flex;align-items:baseline;gap:.75rem;text-decoration:none;color:var(--text);
        padding:.35rem .5rem;border-radius:7px;transition:background .15s;}
      .blog-post-item:hover{background:var(--accent-dim);}
      .blog-post-date{font-size:.69rem;color:var(--text-faint);font-family:'JetBrains Mono',monospace;flex-shrink:0;}
      .blog-post-title{font-size:.82rem;font-weight:500;line-height:1.4;}
      .blog-loading{font-size:.78rem;color:var(--text-faint);font-family:'JetBrains Mono',monospace;padding:.25rem .5rem;}

      @media(max-width:480px){
        .hero-avatar{width:60px;height:60px;background-size:450px auto;}
        .quick-link{font-size:0.7rem;}
        main{padding:1.5rem 1rem 5rem;}
        .group-desc{display:none;}
      }
    </style>
  </head>
  <body>
    <header>
      <div class="header-inner">
        <span class="logo">TNK<span>S</span>1407</span>
        <nav class="nav-links">
